# Direct database connection (port 5432)
# Use this when your network supports IPv6 or you have the Supabase IPv4 add-on.
DATABASE_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres"

# Optional Prisma direct URL for migrations and admin tasks.
# If you're on an IPv4-only network, switch this to your Supabase Session Pooler string instead.
DIRECT_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres"

PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_MAX=120
OWNER_EMAIL=your-email@example.com
ROSHAN_CODE=your-roshan-code
ROSHAN_ACCESS_SECRET=your-long-random-secret
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
